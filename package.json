{
  "name": "json-prompter-monorepo",
  "version": "1.0.0",
  "description": "JSON Prompter — monorepo for Electron app and Chrome extension",
  "private": true,
  "workspaces": [
    "packages/electron",
    "packages/chrome-extension"
  ],
  "scripts": {
    "start:electron":    "npm start -w packages/electron",
    "build:electron:mac": "npm run build:mac -w packages/electron",
    "build:electron:win": "npm run build:win -w packages/electron",
    "build:extension":   "node packages/chrome-extension/build.js",
    "icons:extension":   "node packages/chrome-extension/generate-icons.js"
  }
}
