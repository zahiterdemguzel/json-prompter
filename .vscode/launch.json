{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Electron: Main Process",
      "type": "node",
      "request": "launch",
      "cwd": "${workspaceFolder}/packages/electron",
      "runtimeExecutable": "${workspaceFolder}/node_modules/.bin/electron",
      "runtimeArgs": [".", "--inspect=5858"],
      "windows": {
        "runtimeExecutable": "${workspaceFolder}/node_modules/.bin/electron.cmd"
      },
      "port": 5858,
      "sourceMaps": true,
      "env": {
        "NODE_ENV": "development"
      }
    },
    {
      "name": "Electron: Renderer Process",
      "type": "chrome",
      "request": "attach",
      "port": 9222,
      "webRoot": "${workspaceFolder}/packages/electron/src",
      "timeout": 10000,
      "presentation": {
        "hidden": true
      }
    },
    {
      "name": "Chrome Extension: Content Script",
      "type": "chrome",
      "request": "attach",
      "port": 9222,
      "webRoot": "${workspaceFolder}/packages/chrome-extension",
      "timeout": 10000
    }
  ],
  "compounds": [
    {
      "name": "Electron: Main + Renderer",
      "configurations": ["Electron: Main Process", "Electron: Renderer Process"],
      "presentation": {
        "order": 1
      }
    }
  ]
}
